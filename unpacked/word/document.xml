      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Documentação: </w:t>
      </w:r>
      <w:r>
        <w:t>É obrigatório que a GTA (Guia de Trânsito Animal) indique a finalidade &#x201C;ABATE&#x201D; para garantir a fruição dos benefícios fiscais associados.</w:t>
      </w:r>
      
    </w:p>
