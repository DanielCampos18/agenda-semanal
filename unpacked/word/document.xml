      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Adesão: </w:t>
      </w:r>
      <w:r>
        <w:t>O produtor deve estar habilitado no e-SAPE (Sistema de Apoio à Pecuária Estratégica).</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="648820B7" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
