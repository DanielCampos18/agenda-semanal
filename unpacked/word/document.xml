      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Responsabilidade Social: </w:t>
      </w:r>
      <w:r>
        <w:t>Programas de valorização e formação de empregados.</w:t>
      </w:r>
    </w:p>
