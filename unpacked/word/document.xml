    <w:p w14:paraId="60ADB26B" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo1"/>
      </w:pPr>
      <w:r>
        <w:lastRenderedPageBreak/>
        <w:t>Introdução</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="02A28B4A" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>O PROAPE (Programa de Avanços na Pecuária de Mato Grosso do Sul) é a &#x201C;lei-mãe&#x201D; que sustenta quase todos os incentivos financeiros para a criação de animais no Estado. Para o suinocultor, ele funciona como uma plataforma de modernização: o Estado não dá apenas uma isenção fiscal passiva, mas sim um prémio financeiro em troca de eficiência e sustentabilidade.</w:t>
      </w:r>
      
      
    </w:p>
    <w:p w14:paraId="30C6563F" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>Abaixo, detalho o funcionamento do PROAPE com foco total na suinocultura, integrando as atualizações dos decretos que analisámos anteriormente:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="43E789DA" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="006403C1">
      <w:pPr>
        <w:pBdr>
          <w:bottom w:val="single" w:sz="8" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:spacing w:before="120"/>
      </w:pPr>
    </w:p>
    <w:p w14:paraId="24A04E4F" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo1"/>
      </w:pPr>
      <w:r>
        <w:t>Detalhamento: PROAPE Suinocultura (Leitão Vida)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="34E8E592" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>O PROAPE é subdividido em protocolos. Para quem trabalha com suínos, o braço operacional é o Subprograma &#x201C;Leitão Vida&#x201D;.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="65BBE6B5" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo2"/>
      </w:pPr>
      <w:r>
        <w:t>1. Base Legal e Vigência</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="748E9155" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Lei de Criação: </w:t>
      </w:r>
      <w:r>
        <w:t>Lei nº 2.485/2002.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1C6A5315" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Decreto Regulamentador: </w:t>
      </w:r>
      <w:r>
        <w:t>Decreto nº 11.176/2003 (Texto base).</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="36020101" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Atualização Principal: </w:t>
      </w:r>
      <w:r>
        <w:t>Decreto nº 15.362/2020 (Estabeleceu os critérios atuais de pontuação).</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="05ED5BEF" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Vigência: </w:t>
      </w:r>
      <w:r>
        <w:t>Permanente, com revisões periódicas de metas pela SEMADESC.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7DEC87C2" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo2"/>
      </w:pPr>
      <w:r>
        <w:t>2. O Benefício: &#x201C;Dinheiro no Bolso&#x201D; via ICMS</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7621168F" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>Diferente de uma simples redução de alíquota, o PROAPE concede um crédito outorgado. Na prática, o frigorífico retém menos imposto do produtor, repassando esse valor como um &#x201C;bónus&#x201D; pela qualidade do animal.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="6E6B5A2B" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="18" w:space="8" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="80" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Até 50% de devolução: </w:t>
      </w:r>
      <w:r>
        <w:t>O benefício pode representar uma recuperação de até 50% do ICMS devido na operação de abate.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="276F04F4" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="18" w:space="8" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="80" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Isenção Excedente (Art. 1º do Dec. 15.362/2020): </w:t>
      </w:r>
      
      <w:r>
        <w:t>Nas operações com animais que ultrapassarem o &#x201C;teto por matriz&#x201D; definido pelo Estado em 12 meses, o incentivo pode chegar a 100% do ICMS.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="691DDCAE" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo2"/>
      </w:pPr>
      <w:r>
        <w:t>3. Os Pilares de Pontuação (Como ganhar mais)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="39A7E976" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>O PROAPE não paga o mesmo para todos. O valor do subsídio depende de quantos pontos a sua granja soma nos seguintes critérios:</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="79B41D12" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Sanidade Animal (Obrigatório): </w:t>
      </w:r>
      <w:r>
        <w:t>Cumprimento rigoroso do calendário de vacinação e normas da IAGRO.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0DCC2724" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Genética: </w:t>
      </w:r>
      <w:r>
        <w:t>Uso de matrizes e reprodutores com certificado de origem e alto desempenho.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="6C063D42" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Sustentabilidade (Diferencial): </w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4668FB1F" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
        <w:ind w:left="1080"/>
      </w:pPr>
      <w:r>
        <w:t>Uso de biodigestores para tratamento de dejetos.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4476AEB3" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
        <w:ind w:left="1080"/>
      </w:pPr>
      <w:r>
        <w:t>Geração de energia limpa (biogás).</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="1818EC16" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
        <w:ind w:left="1080"/>
      </w:pPr>
      <w:r>
        <w:lastRenderedPageBreak/>
        <w:t>Reuso de água ou captação de água da chuva.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0F25C06B" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Social: </w:t>
      </w:r>
      <w:r>
        <w:t>Regularidade trabalhista e programas de formação para os funcionários da granja.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="365373BB" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo2"/>
      </w:pPr>
      <w:r>
        <w:t>4. Como Fazer Parte (Passo a Passo)</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="3A8BA2E1" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="160" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="001B47"/>
          <w:sz w:val="24"/>
        </w:rPr>
        <w:t>Passo 1: Inscrição no e-SAPE</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="19F45254" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:t>O produtor deve aceder ao portal da SEMADESC e registar-se no e-SAPE (Sistema de Apoio à Pecuária Estratégica). É o portal oficial onde todos os dados da produção são inseridos.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="4D072A05" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="160" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="001B47"/>
          <w:sz w:val="24"/>
        </w:rPr>
        <w:t>Passo 2: Adesão ao Protocolo PLVC</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="26E3E2ED" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:t>O produtor assina o termo de adesão ao Protocolo Leitão Vida em Conformidade (PLVC). Neste momento, ele declara em qual nível de tecnologia sua granja se enquadra.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0F856129" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="160" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="001B47"/>
          <w:sz w:val="24"/>
        </w:rPr>
        <w:t>Passo 3: Auditoria da IAGRO</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0AED2B2E" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:t>Técnicos da IAGRO ou entidades credenciadas visitarão a propriedade para verificar se o que foi declarado no e-SAPE é real. Eles darão uma nota de 0 a 100.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="479E298D" w14:textId="587BF658" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="18" w:space="8" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="80" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Acima de 90 pontos: </w:t>
      </w:r>
      <w:r>
        <w:t>Nível Avançado (Recebe o benefício máximo de 4,38%).</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="19ACD5A6" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="160" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="001B47"/>
          <w:sz w:val="24"/>
        </w:rPr>
        <w:t>Passo 4: Abate em Frigorífico Credenciado</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="168D0977" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:t>O benefício só se materializa se o abate for feito em plantas frigoríficas que também aderiram ao PROAPE. O sistema da SEFAZ cruza os dados da GTA (Guia de Trânsito Animal) com a nota fiscal e liberta o crédito automaticamente.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="3BB0CAA2" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="006403C1">
      <w:pPr>
        <w:pBdr>
          <w:bottom w:val="single" w:sz="8" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:spacing w:before="120"/>
      </w:pPr>
    </w:p>
    <w:p w14:paraId="085A8FBB" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo1"/>
      </w:pPr>
      <w:r>
        <w:t>A Conexão Crítica com o Decreto 15.628/2021</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="1548BB79" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>Para manter o benefício do PROAPE, o produtor não pode ter dívidas com o FUNDERSUL ou FUNDEMS. Como o Decreto nº 15.628/2021 permitiu diferir essas contribuições para o momento da entrada na indústria, se a sua fábrica de ração atrasar o pagamento destas taxas, o seu cadastro no PROAPE pode ser suspenso, bloqueando os bónus de abate.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="224CCFD3" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:top w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
          <w:bottom w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
          <w:right w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="240" w:after="80"/>
        <w:ind w:left="284" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="001B47"/>
          <w:sz w:val="24"/>
        </w:rPr>
        <w:t>Resumo do Sucesso no PROAPE:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="77CD9456" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
          <w:right w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="40" w:after="40"/>
        <w:ind w:left="568" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="AF946C"/>
        </w:rPr>
        <w:t xml:space="preserve">•  </w:t>
      </w:r>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Mantenha a IAGRO atualizada </w:t>
      </w:r>
      <w:r>
        <w:t>(Sanidade).</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="24C09A69" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
          <w:right w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="40" w:after="40"/>
        <w:ind w:left="568" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="AF946C"/>
        </w:rPr>
        <w:t xml:space="preserve">•  </w:t>
      </w:r>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Invista em Meio Ambiente </w:t>
      </w:r>
      <w:r>
        <w:t>(Biodigestores aumentam a sua margem de lucro via bónus).</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="0BF068AB" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="24" w:space="8" w:color="001B47"/>
          <w:bottom w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
          <w:right w:val="single" w:sz="4" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:shd w:val="clear" w:color="auto" w:fill="E8EDF5"/>
        <w:spacing w:before="40" w:after="40"/>
        <w:ind w:left="568" w:right="284"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
          <w:color w:val="AF946C"/>
        </w:rPr>
        <w:t xml:space="preserve">•  </w:t>
      </w:r>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Pague o FUNDERSUL/FUNDEMS até ao dia 10 </w:t>
      </w:r>
      <w:r>
        <w:t>(Regularidade fiscal).</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="20EC1647" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="006403C1">
      <w:pPr>
        <w:pBdr>
          <w:bottom w:val="single" w:sz="8" w:space="1" w:color="AF946C"/>
        </w:pBdr>
        <w:spacing w:before="120"/>
      </w:pPr>
    </w:p>
    <w:p w14:paraId="1C1F7770" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo1"/>
      </w:pPr>
      <w:r>
        <w:t>Programa Leitão Vida – Detalhes Técnicos</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="7E35CEC3" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>O Programa Leitão Vida é o braço do PROAPE focado exclusivamente na suinocultura de Mato Grosso do Sul, funcionando como um incentivo financeiro direto ao produtor que investe em qualidade, sanidade e sustentabilidade.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="714A0F30" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:lastRenderedPageBreak/>
        <w:t>Aqui estão os detalhes técnicos atualizados deste programa:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="4135AA7C" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Ttulo2"/>
      </w:pPr>
      <w:r>
        <w:t>1. O Benefício Financeiro</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="42DA2F3D" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>O principal atrativo é um incentivo financeiro por animal abatido, que é calculado como um crédito outorgado sobre o ICMS da operação.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="475308FB" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pBdr>
          <w:left w:val="single" w:sz="18" w:space="8" w:color="AF946C"/>
