    </w:p>
    <w:p w14:paraId="0613DB60" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:r>
        <w:t>Para alcançar os níveis mais altos de premiação, o Estado valoriza práticas específicas:</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="42D3B310" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Sustentabilidade: </w:t>
      </w:r>
      <w:r>
        <w:t>Instalação de biodigestores para geração de energia e sistemas de captação de água da chuva.</w:t>
      </w:r>
      
    </w:p>
    <w:p w14:paraId="4E8947B3" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
      <w:pPr>
        <w:pStyle w:val="Commarcadores"/>
        <w:spacing w:before="40" w:after="60"/>
      </w:pPr>
      <w:r>
        <w:rPr>
          <w:b/>
        </w:rPr>
        <w:t xml:space="preserve">Manejo e Bem-estar: </w:t>
      </w:r>
      <w:r>
        <w:t>Conformidade com 15 itens obrigatórios de biosseguridade e sanidade animal.</w:t>
      </w:r>
    </w:p>
    <w:p w14:paraId="03908489" w14:textId="77777777" w:rsidR="006403C1" w:rsidRDefault="00D932F5">
